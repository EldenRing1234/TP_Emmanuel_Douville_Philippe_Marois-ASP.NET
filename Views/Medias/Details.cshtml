@model Models.Media
@{ ViewBag.PageTitle = "Détails"; }

<div id="detailsPanel">
    <div class="detailsPanel">
        <dl>
            <dd>
                @Model.Title
            </dd>
            <dd>
                @Helper.YoutubePlayer(Model.YoutubeId)
            </dd>
            <dd class="description">
                @Model.Description
            </dd>
            <dt>
                Catégorie
            </dt>

            <dd>
                @Model.Category
            </dd>

            <dt>
                Date de publication
            </dt>

            <dd>
                @Helper.When(Model.PublishDate)
            </dd>

        </dl>
    </div>
</div>

@section Scripts {
    <script>$(() => {
            let detailsAutoRefreshPanel =
                new AutoRefreshedPanel(
                    "detailsPanel",
                    "/Medias/GetDetails",
                    5,   // refresh every 5 seconds
                    null // no callback needed
                );
        });</script>
}